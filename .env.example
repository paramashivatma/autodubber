# AutoDub Studio environment template
# Copy to .env and fill values. Never commit .env.
#
# Canonical keys (recommended):
# - GROQ_API_KEY: transcription acceleration
# - GEMINI_API_KEY: translation + vision + flyer captioning
# - MISTRAL_API_KEY: caption generation
# - ZERNIO_API_KEY: publishing
# - GOOGLE_SHEET_ID: optional sheet logging
# - GOOGLE_CREDENTIALS_FILE: optional service account file path
# - PIPELINE_MODE: economy or quality
#
# Legacy aliases still supported:
# GOOGLE_API_KEY, GEMINI_VISION_KEY, OPENROUTER_API_KEY, SHEET_ID

GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
MISTRAL_API_KEY=your_mistral_key_here
ZERNIO_API_KEY=your_zernio_key_here
ZERNIO_INSTAGRAM_ACCOUNT_ID=
ZERNIO_FACEBOOK_ACCOUNT_ID=
ZERNIO_YOUTUBE_ACCOUNT_ID=
ZERNIO_THREADS_ACCOUNT_ID=
ZERNIO_TWITTER_ACCOUNT_ID=
ZERNIO_TIKTOK_ACCOUNT_ID=
ZERNIO_BLUESKY_ACCOUNT_ID=

GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

PIPELINE_MODE=economy
