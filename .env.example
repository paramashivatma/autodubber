# AutoDub Studio environment template
# Copy to .env and fill values. Never commit .env.
#
# Canonical keys (recommended):
# - DEEPGRAM_API_KEY: transcription acceleration (nova-3)
# - GEMINI_API_KEY: translation + vision + flyer captioning
# - MISTRAL_API_KEY: caption generation
# - GLM_API_KEY: optional eval-only caption generation
# - ZERNIO_API_KEY: publishing
# - GOOGLE_SHEET_ID: optional sheet logging
# - GOOGLE_CREDENTIALS_FILE: optional service account file path
# - PIPELINE_MODE: economy or quality
# - DUB_SOURCE_LANG / DUB_TARGET_LANG / DUB_VOICE: optional startup defaults for the Dub Video tab
#
# Legacy aliases still supported:
# GOOGLE_API_KEY, GEMINI_VISION_KEY, OPENROUTER_API_KEY, SHEET_ID

DEEPGRAM_API_KEY=your_deepgram_key_here
GEMINI_API_KEY=your_gemini_key_here
MISTRAL_API_KEY=your_mistral_key_here
GLM_API_KEY=
GLM_MODEL=glm-5.1
# Override only if your Modal GLM account uses a different endpoint.
GLM_BASE_URL=https://api.modal.com/v1/glm-5
GLM_MAX_TOKENS=2048
# Eval-only: compare GLM captions against Mistral without changing live publishing.
GLM_CAPTION_EVAL=0
ZERNIO_API_KEY=your_zernio_key_here
ZERNIO_INSTAGRAM_ACCOUNT_ID=
ZERNIO_FACEBOOK_ACCOUNT_ID=
# Threads (Meta) — account id from Zernio dashboard (hex string)
ZERNIO_THREADS_ACCOUNT_ID=
ZERNIO_TWITTER_ACCOUNT_ID=
ZERNIO_TIKTOK_ACCOUNT_ID=
ZERNIO_BLUESKY_ACCOUNT_ID=
# Bluesky in this app posts only via AT Proto (not Zernio). Set both:
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

YOUTUBE_HDH_GUJARATI_CLIENT_ID=
YOUTUBE_HDH_GUJARATI_CLIENT_SECRET=
YOUTUBE_KAILAASA_GUJARATI_CLIENT_ID=
YOUTUBE_KAILAASA_GUJARATI_CLIENT_SECRET=

GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

PIPELINE_MODE=economy
DUB_SOURCE_LANG=en
DUB_TARGET_LANG=gu
DUB_VOICE=gu-IN-NiranjanNeural
